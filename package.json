{
  "name": "psx-portfolio",
  "version": "1.0.0",
  "description": "PSX portfolio management platform",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "main": "index.js",
  "scripts": {
    "scraper:start": "node index.js",
    "dev:backend": "npm run start:dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "db:create": "node scripts/create-dev-db.js",
    "db:migrate": "npm run db:migrate --workspace backend",
    "build": "npm run build --workspaces --if-present",
    "test": "node --check index.js && npm run test --workspace backend -- --runInBand",
    "lint": "npm run lint --workspaces --if-present"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "sharp": "^0.35.3"
  },
  "overrides": {
    "next": {
      "sharp": "0.35.3"
    }
  }
}
